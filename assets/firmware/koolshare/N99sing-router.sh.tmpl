#!/bin/sh
# sing-router — koolshare nat-start hook (managed by `sing-router install`; do not edit)
# Invoked by /koolshare/bin/ks-nat-start.sh after NAT/firewall comes up.
# $1 is the action passed by /jffs/scripts/nat-start (currently always "start_nat").

ACTION=$1
LOG=/tmp/sing-router-nat-start.log
# 绝对路径在 install 时渲染（默认 /opt/sbin/sing-router）。
# Asus 触发 nat-start 时 PATH 只有 /sbin:/usr/sbin:/bin:/usr/bin（不含 /opt/sbin），
# 之前 `which sing-router` guard 在该上下文恒为假 —— WAN 重拨后 iptables 再也补不回来。
BINARY="{{.Binary}}"

# log 同时落 /tmp 文件与 syslog；这条链路在 sing-router.log 里看不到，
# WAN 重拨后 iptables 没补回时，先看这里确认钩子有没有被触发、reapply 结果如何。
log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') N99sing-router: $*" >> "$LOG"
    logger -t sing-router-nat-start "$*" 2>/dev/null
}

# Guard: if entware isn't mounted yet (early boot), the binary won't exist.
if [ ! -x "$BINARY" ]; then
    log "skipped (action=$ACTION): $BINARY not executable (entware not mounted yet?)"
    exit 0
fi

case "$ACTION" in
    start_nat|"" )
        # 错峰避让：固件 start_nat / 开机 start_firewall 会并发重建 nat 表、(重)启
        # miniupnpd。这台路由器的 iptables(v1.4.12)不支持 -w 等锁，多方同时改表会撞
        # xtables 锁、报 "Resource temporarily unavailable" 静默失败（实测 sing-router
        # 自身重启都曾因此首次失败）。先睡几秒让固件那阵 iptables 风暴沉淀、miniupnpd
        # 把 VUPNP/FUPNP 链建好，再让 sing-router 动手——既降低自身失败概率，也确保
        # startup.sh 末尾补 miniupnpd 链跳转时这两条链已就绪。
        # 整数秒：busybox sleep 不支持小数（见 TestEmbeddedShellScriptsBusyboxSleep）。
        sleep 5
        # --force 绕节流：固件 start_nat 通常意味着 iptables 刚被 flush，必须真生效。
        log "restart --force start (action=$ACTION)"
        OUT=$("$BINARY" restart --force 2>&1)
        RC=$?
        if [ "$RC" -eq 0 ]; then
            log "restart ok (action=$ACTION)"
        else
            log "restart FAILED rc=$RC (action=$ACTION): $OUT"
        fi
        ;;
    * )
        log "ignored action=$ACTION"
        ;;
esac
exit 0
