{
  "dns": {
    "servers": [
      // Resolver
      { "tag": "dns-resolver", "type": "udp", "server": "223.5.5.5" },
      // Direct
      { "tag": "dns-direct", "type": "h3", "server": "dns.alidns.com", "domain_resolver": "dns-resolver" },
      // Proxy
      { "tag": "dns-one", "type": "h3", "server": "one.one.one.one", "detour": "🔰 默认出口" },
      { "tag": "dns-cloudflare", "type": "h3", "server": "cloudflare-dns.com", "detour": "🔰 默认出口" },
      { "tag": "dns-proxy", "type": "group", "servers": ["dns-one", "dns-cloudflare"] },
      // Hosts
      {
        "tag": "dns-hosts",
        "type": "hosts",
        "path": ["config.d/hosts", "/etc/hosts"]
      },
      // FakeIP
      { "tag": "dns-fakeip", "type": "fakeip", "inet4_range": "28.0.0.0/8" }
    ],
    "rules": [
      // Hosts
      {
        "domain": [
          "localhost.localdomain",
          "localhost",
          "ip6-localhost",
          "ip6-loopback",
          "ip6-localnet",
          "ip6-mcastprefix",
          "ip6-allnodes",
          "ip6-allrouters"
        ],
        "action": "predefined",
        "rcode": "NXDOMAIN"
      },
      { "preferred_by": "dns-hosts", "server": "dns-hosts" },
      // Clash
      { "clash_mode": "Direct", "server": "dns-direct" },
      { "clash_mode": "Global", "server": "dns-fakeip" },
      // Direct
      { "action": "evaluate", "server": "dns-direct" },
      { "rule_set": ["Lan", "FakeIpBypass", "GeoSites@CN"], "action": "respond" },
      { "match_response": true, "rule_set": "GeoIP@CN", "action": "respond" },
      { "query_type": ["A", "AAAA"], "server": "dns-fakeip", "rewrite_ttl": 1 }
    ],
    "final": "dns-proxy",
    "reverse_mapping": true,
    "strategy": "prefer_ipv6"
  },
  "route": {
    "rules": [
      // 防自连回环
      {
        "source_ip_cidr": ["127.0.0.0/8", "::1/128", "192.168.50.1/32"],
        "inbound": ["dns-in", "redirect-in", "tproxy-in", "tun-in"],
        "action": "reject"
      },
      { "inbound": "dns-in", "action": "hijack-dns" },
      { "network": "icmp", "outbound": "DIRECT" },
      { "ip_is_private": true, "outbound": "DIRECT" },
      // 禁用 DoT/DoQ
      { "port": 853, "action": "reject" },
      { "action": "sniff" },
      { "protocol": "dns", "action": "hijack-dns" },
      // 禁用 DoH
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          { "rule_set": "GeoSites@CN", "invert": true },
          { "protocol": ["http", "tls", "quic"], "rule_set": "DoH" }
        ],
        "action": "reject"
      },
      { "protocol": ["bittorrent", "ntp", "stun"], "outbound": "DIRECT" },
      { "action": "sniff-override-destination" }
    ],
    "auto_detect_interface": true,
    "default_domain_resolver": "dns-direct",
    "default_mark": "0x7890"
  }
}
// vim: ft=jsonc
