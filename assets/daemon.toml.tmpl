# /opt/home/sing-router/daemon.toml
# 该文件在首次 `sing-router install` 时由模板生成；之后由用户维护，
# 后续运行 `install` 不会覆盖此文件（包括其中的 firmware 与 download 选项）。

[runtime]
# rundir = "/opt/home/sing-router"   # 默认 = -D 参数 / 启动 cwd
sing_box_binary = "bin/sing-box"
config_dir      = "config.d"
ui_dir          = "ui"

[http]
listen          = "127.0.0.1:9998"
# token         = ""                 # A 阶段不启用，D 阶段加

[log]
# level 控本地 log 文件（log/sing-router.log）的级别下限；与 [seq].level
# 各自独立——本地详细 / 远程精简 这种组合是支持的（典型：[log].level="info"
# + [seq].level="warn"）。emitter 入口 floor 自动取两者更低值，低于 floor
# 的事件根本不会进 bus。
level           = "info"
file            = "log/sing-router.log"
rotate          = "internal"
max_size_mb     = 10
max_backups     = 5
# color_profile 控制 `sing-router logs` 渲染的颜色能力：
#   auto       — 按 NO_COLOR / COLORTERM / TERM 环境变量推断（路由器无 TERM 通常退回 none）
#   truecolor  — 24bit RGB（最现代的终端如 iTerm2 / 新版 tmux）
#   256        — xterm-256
#   8          — 基础 8 色（最保守）
#   none       — 关色
color_profile   = "auto"
include_stack   = false

[supervisor]
# ready_check_dial_inbounds = true 时，daemon 只 dial mixed-in (127.0.0.1:7890)
# 探活；绝不 dial dns-in (1053) / redirect-in (7892)——那两个是 transparent
# 入站，本机自连即触发 sing-box 自身回环（CPU 100%）。
# ready_check_dial_inbounds       = true
# ready_check_clash_api           = true
# ready_check_timeout_ms          = 60000
# ready_check_interval_ms         = 200
# crash_pre_ready_action          = "fatal"
# crash_post_ready_backoff_ms     = [1000, 2000, 4000, 8000, 16000, 32000, 64000, 128000, 256000, 512000, 600000]
# stop_grace_seconds              = 5
# route_watch_interval_sec        = 30   # 周期巡检 `default dev <TUN> table N`，
#                                        # 兜底外部 kill -HUP sing-box 触发的 TUN 重建（丢路由时调 Restart）

[zoo]
extract_keys              = ["outbounds", "route.rules", "route.rule_set", "route.final"]
rule_set_dedup_strategy   = "builtin_wins"
outbound_collision_action = "reject"

[download]
# cn.txt 走公网 cdn，不走 gitee；sing-box / zoo 见 [gitee] 节。
cn_list_url              = "https://cdn.jsdelivr.net/gh/juewuy/ShellCrash@update/bin/geodata/china_ip_list.txt"
http_timeout_seconds     = 60
http_retries             = 3

[gitee]
# 必填：私仓 access_token；也可由环境变量 SING_ROUTER_GITEE_TOKEN 覆盖，或 install 时传 --gitee-token。
token = "{{ .GiteeToken }}"
owner = "moonfruit"
repo  = "private"

[gitee.sing_box]
ref                   = "binary"
version_path          = "version.txt"
tarball_path_template = "sing-box-{version}-linux-arm64-musl.tar.gz"

[gitee.zoo]
ref  = "main"
path = "config.json"

# rule_set 处理：dns.json 不再自带 rule_set 定义，daemon 启动时 EnsureRequiredRuleSets
# 会按需把缺失的 tag 写到 config.d/rule-set.json，URL 直接是 https://gitee.com/...
# （含 access_token），不走 proxy。用户的 zoo.raw.json 若已声明同名 tag 则优先生效。
# ref 复用 [gitee.zoo].ref（默认 "main"）。

[sync]
# 后台周期同步：interval_seconds = 0 即禁用（仅留 sing-router update CLI）。
interval_seconds   = 21600
on_start_delay_sec = 300

[seq]
# 远程 Seq 日志汇聚（sing2seq v1.3.0+ 的 seq.Sink）；默认关闭。
# 启用条件 = enabled = true 且 url 非空。任一不满足 daemon 启动会发一条
# seq.disabled 事件后继续运行（不退出）。
#
# Source 字段约定（Seq UI 用它切视图）：
#   - daemon    — sing-router daemon 自身事件
#   - sing-box  — 来自 sing-box stderr 的解析事件
#   - sing2seq  — seq.Sink 自身诊断（buffer_overflow / post_failed / shutdown_post_failed）
#
# 关闭顺序：daemon shutdown 时按 close_drain_timeout_seconds 同步 drain
# sink pending 队列；超时后放弃 pending、daemon 仍能退出。跨公网 Seq
# 应适当调大 close_drain_timeout_seconds。
#
# enabled  = false
# url      = "http://seq.lan:5341"    # 不要加 /ingest/clef 后缀
# api_key  = ""                       # 非空时发 X-Seq-ApiKey header
# insecure = false                    # true 时 TLS 跳过证书验证
# level    = "info"                   # trace/debug/info/warn/error/fatal；与 [log].level 各自独立
# 以下高级调优字段留空走 seq.Sink 默认（与上游 sing2seq CLI 一致）：
# batch_size                  = 200
# channel_buffer              = 1024
# max_pending                 = 50000
# drop_target                 = 25000
# initial_backoff_ms          = 1000
# max_backoff_ms              = 60000
# close_drain_timeout_seconds = 10
#
# 也可由环境变量 SING_ROUTER_SEQ_URL / SING_ROUTER_SEQ_API_KEY 覆盖
# 对应字段（仅覆盖值，enabled 仍由本节决定，避免误启用）。

[notify]
# 多渠道状态变化通知（Bark 等）。默认完全关闭——enabled=false 或没有任何
# enabled 的渠道时不构造 notifier、不订阅 bus。
#
# 哪些事件会通知由内置目录决定（资源更新 apply.ok、sing-box 崩溃/恢复、路由
# 丢失、daemon 启停、各类失败等）；用户只能开关与调阈值，不能改文案。
#
# enabled        = false
# min_priority   = "low"     # 全局阈值 low/normal/high/critical；低于它的通知丢弃
# disabled_kinds = ["sync.item.failed"]   # 按 Kind（=事件 EventID）精确关闭
# close_drain_timeout_seconds = 5          # 关停时排空 pending 通知的预算秒数
#
# 渠道用 array-of-tables，可配多个（手机 / iPad 各设阈值）：
# [[notify.bark]]
# name         = "phone"
# enabled      = true
# base_url     = "https://api.day.app"   # 可换成自建 bark-server
# key          = ""                      # Bark 设备 key（必填）
# group        = "sing-router"           # 通知中心归组名
# min_priority = "low"                   # 可选，本渠道单独抬高阈值（只能更严）
#
# 可选端到端加密推送（需在 Bark App 配置一致的算法与 key）：
# [notify.bark.encryption]
# algorithm = "AES256"     # AES128 / AES192 / AES256
# mode      = "CBC"        # CBC / ECB / GCM（Bark 官方文档仅明确 CBC）
# key       = ""           # 长度须匹配 algorithm（16/24/32 字节）
#
# 也可由环境变量 SING_ROUTER_BARK_KEY 覆盖第一个 [[notify.bark]] 的 key。

[router]
# dns_port      = 1053
# redirect_port = 7892
# route_mark    = "0x7892"
# bypass_mark   = "0x7890"
# tun           = "utun"
# fakeip        = "28.0.0.0/8"   # 必须与 dns.json inet4_range 一致
# lan           = "192.168.50.0/24"
# lan_iface     = "br0"            # LAN 网桥接口；FORWARD REJECT 兜底用 -i 收窄
# route_table   = 7892
# proxy_ports   = "22,80,443,8080,8443"

[install]
# 本节在首次 install 时由命令行参数（或探测结果）渲染；之后由用户维护。
download_sing_box   = {{ .DownloadSingBox }}
download_cn_list    = {{ .DownloadCNList }}
auto_start          = {{ .AutoStart }}
firmware            = "{{ .Firmware }}"

[zashboard]
# ui/zashboard.json（zashboard web 可导入的 source-ip-label-list）生成所用的静态标签表。
# ui_dir 存在即每轮 sync 生成；路由器 custom_clientlist 数据优先，下表只补缺失的 key。
[zashboard.static_labels]
"127.0.0.1"         = "🌐本机"
"11.0.0.1"          = "🌐TUN"
"192.168.50.1"      = "🛜主路由器"
"192.168.50.2"      = "🛜副路由器"
"192.168.50.3"      = "🛜小路由器"
